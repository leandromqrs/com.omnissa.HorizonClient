<component type="desktop">
    <id>com.omnissa.HorizonClient</id>
    <metadata_license>CC0-1.0</metadata_license>
    <name>Omnissa Horizon Client</name>
    <summary>Omnissa Horizon is a modern platform for running and delivering virtual desktops and apps across the hybrid
        cloud.
    </summary>
    <description>
        <p>
            Omnissa Horizon Client is software that allows you to connect your Omnissa Horizon virtual desktop to a device
            of choice, giving you on-the-go access from any location.
            Clients are available for Windows, Mac, iOS, Linux, Chrome and Android and may be downloaded from
            customerconnect.omnissa.com.
        </p>
    </description>

    <url type="homepage">https://www.omnissa.com/products/horizon/</url>
    <url type="help">https://customerconnect.omnissa.com</url>

    <releases>
        <release version="2603" date="2026-04-14">
            <url>https://customerconnect.omnissa.com/downloads/details?downloadGroup=CART27FQ1_LIN_2603_TARBALL&amp;productId=1616&amp;rPId=119132</url>
            <description>See url for more details.</description>
        </release>
        <release version="2111" date="2021-11-29">
            <description>See url for more details.</description>
        </release>
    </releases>

